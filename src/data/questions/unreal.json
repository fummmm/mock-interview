    {"id": "unreal-intro", "text": "자기소개와 함께 Unreal Engine 개발자를 지망하게 된 계기를 말씀해주세요.", "category": "behavioral", "difficulty": "basic", "keywords": ["자기소개", "Unreal", "지원 동기"], "evaluationHints": "간결한 자기소개, Unreal 선택 이유"},
