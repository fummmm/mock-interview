{
  "track": "pm",
  "trackLabel": "PM",
  "questions": [
    {"id": "pm-intro", "text": "자기소개와 함께 PM 직무를 지망하게 된 계기를 말씀해주세요.", "category": "behavioral", "difficulty": "basic", "keywords": ["자기소개", "PM", "지원 동기"], "evaluationHints": "간결한 자기소개, PM 직무 이해도"},
    {"id": "pm-001", "text": "좋은 게임 기획서의 조건은 무엇이라고 생각하나요?", "category": "technical", "difficulty": "basic", "keywords": ["기획서", "문서화", "커뮤니케이션"], "evaluationHints": "기획서 구성 요소와 목적 이해"},
    {"id": "pm-002", "text": "프로젝트 일정 관리를 어떻게 하나요? 사용하는 도구나 방법론이 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["일정 관리", "간트 차트", "스프린트", "도구"], "evaluationHints": "구체적 도구와 방법론 경험"},
    {"id": "pm-003", "text": "애자일(Agile)과 워터폴(Waterfall) 방식의 차이점을 설명해주세요. 게임 개발에는 어떤 방식이 적합한가요?", "category": "technical", "difficulty": "intermediate", "keywords": ["애자일", "워터폴", "스크럼", "개발 방법론"], "evaluationHints": "방법론 이해와 게임 개발 적용"},
    {"id": "pm-004", "text": "기획 의도와 개발 결과물이 다를 때 어떻게 대처하나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["커뮤니케이션", "기획 변경", "이해관계"], "evaluationHints": "상황 대처와 소통 방법"},
    {"id": "pm-005", "text": "유저 리서치나 플레이테스트를 진행한 경험이 있나요? 어떻게 피드백을 반영했나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["유저 리서치", "플레이테스트", "피드백", "데이터"], "evaluationHints": "리서치 방법과 데이터 활용"},
    {"id": "pm-006", "text": "게임의 핵심 재미 요소(Core Loop)를 설계한 경험이 있나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["코어 루프", "게임 메카닉", "재미", "리텐션"], "evaluationHints": "코어 루프 개념과 설계 경험"},
    {"id": "pm-007", "text": "KPI를 설정하고 추적한 경험이 있나요? 어떤 지표를 중요하게 봤나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["KPI", "지표", "DAU", "리텐션", "ARPU"], "evaluationHints": "게임 KPI 이해와 데이터 기반 의사결정"},
    {"id": "pm-008", "text": "BM(비즈니스 모델) 기획을 해본 적이 있나요? F2P 게임의 수익 모델에 대해 말씀해주세요.", "category": "technical", "difficulty": "intermediate", "keywords": ["BM", "F2P", "인앱결제", "수익 모델"], "evaluationHints": "BM 구조 이해와 유저 경험 균형"},
    {"id": "pm-009", "text": "밸런스 설계를 어떻게 접근하나요? 수치 밸런싱 경험이 있나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["밸런스", "수치", "시뮬레이션", "테스트"], "evaluationHints": "밸런스 접근 방법론"},
    {"id": "pm-010", "text": "경쟁 게임 분석(벤치마크)을 어떻게 하나요? 실제로 해본 경험이 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["벤치마크", "경쟁 분석", "시장 조사"], "evaluationHints": "분석 프레임워크와 결과 활용"},
    {"id": "pm-011", "text": "게임 내 UI/UX를 기획할 때 가장 중요하게 생각하는 것은 무엇인가요?", "category": "technical", "difficulty": "basic", "keywords": ["UI", "UX", "사용성", "직관성"], "evaluationHints": "유저 관점의 UI/UX 이해"},
    {"id": "pm-012", "text": "개발팀과 의견이 충돌할 때 어떻게 설득하거나 조율하나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["설득", "조율", "갈등 해결", "커뮤니케이션"], "evaluationHints": "구체적 경험과 소통 방식"},
    {"id": "pm-013", "text": "기획 변경(스코프 변경)이 발생했을 때 어떻게 대응하나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["스코프", "변경 관리", "우선순위"], "evaluationHints": "변경 관리 프로세스 이해"},
    {"id": "pm-014", "text": "JIRA, Notion, Confluence 등 프로젝트 관리 도구를 사용한 경험이 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["JIRA", "Notion", "협업 도구", "이슈 트래킹"], "evaluationHints": "도구 활용 경험과 워크플로"},
    {"id": "pm-015", "text": "레벨 디자인이나 콘텐츠 설계를 해본 경험이 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["레벨 디자인", "콘텐츠", "난이도 곡선"], "evaluationHints": "콘텐츠 설계 경험과 유저 경험 고려"},
    {"id": "pm-016", "text": "가장 최근에 참여한 게임 프로젝트에 대해 설명해주세요.", "category": "behavioral", "difficulty": "basic", "keywords": ["프로젝트", "역할", "성과"], "evaluationHints": "구체적 기여와 결과"},
    {"id": "pm-017", "text": "실패한 프로젝트나 기각된 기획안이 있나요? 그 경험에서 무엇을 배웠나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["실패", "교훈", "성장"], "evaluationHints": "실패 인정과 교훈 도출"},
    {"id": "pm-018", "text": "최근 플레이한 게임 중 하나를 분석해주세요. 장점과 개선점은?", "category": "technical", "difficulty": "basic", "keywords": ["게임 분석", "장단점", "비판적 사고"], "evaluationHints": "기획자 관점의 분석력"},
    {"id": "pm-019", "text": "데이터 분석 도구(엑셀, SQL, 구글 애널리틱스 등)를 사용해본 경험이 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["데이터 분석", "엑셀", "SQL", "분석 도구"], "evaluationHints": "데이터 활용 능력"},
    {"id": "pm-020", "text": "라이브 서비스 운영(업데이트, 이벤트 기획 등)에 대해 어떻게 생각하나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["라이브 서비스", "업데이트", "이벤트", "운영"], "evaluationHints": "라이브 서비스 이해와 경험"},
    {"id": "pm-021", "text": "기획서를 작성할 때 본인만의 원칙이나 템플릿이 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["기획서", "문서화", "템플릿", "원칙"], "evaluationHints": "체계적 문서화 능력"},
    {"id": "pm-022", "text": "팀원의 사기가 떨어졌을 때 어떻게 동기부여를 하나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["동기부여", "리더십", "팀 관리"], "evaluationHints": "리더십과 공감 능력"},
    {"id": "pm-023", "text": "본인의 강점과 약점은 무엇인가요?", "category": "behavioral", "difficulty": "basic", "keywords": ["강점", "약점", "자기 인식"], "evaluationHints": "솔직한 자기 인식"},
    {"id": "pm-024", "text": "새로운 게임 장르나 트렌드를 어떻게 파악하고 있나요?", "category": "behavioral", "difficulty": "basic", "keywords": ["트렌드", "시장", "게임 문화"], "evaluationHints": "업계 관심과 정보 수집 방법"},
    {"id": "pm-025", "text": "QA(품질 보증) 프로세스에서 PM의 역할은 무엇이라고 생각하나요?", "category": "technical", "difficulty": "basic", "keywords": ["QA", "테스트", "품질", "PM 역할"], "evaluationHints": "QA 프로세스 이해와 PM 관점"},
    {"id": "pm-026", "text": "시스템 기획(전투, 성장, 경제 등) 중 가장 관심 있는 분야는?", "category": "technical", "difficulty": "basic", "keywords": ["시스템 기획", "전투", "성장", "경제"], "evaluationHints": "관심 분야의 깊이"},
    {"id": "pm-027", "text": "글로벌 서비스를 위한 현지화(로컬라이제이션)에 대해 어떻게 생각하나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["현지화", "글로벌", "문화", "번역"], "evaluationHints": "현지화 이해와 고려 사항"},
    {"id": "pm-028", "text": "마감이 촉박한 상황에서 스코프를 줄여야 한다면 어떤 기준으로 결정하나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["스코프", "우선순위", "MVP", "의사결정"], "evaluationHints": "판단 기준과 실제 경험"},
