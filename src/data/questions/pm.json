{
  "track": "pm",
  "trackLabel": "PM",
  "questions": [
    {"id": "pm-intro", "text": "자기소개와 함께 PM 직무를 지망하게 된 계기를 말씀해주세요.", "category": "behavioral", "difficulty": "basic", "keywords": ["자기소개", "PM", "지원 동기"], "evaluationHints": "간결한 자기소개, PM 직무 이해도"},
    {"id": "pm-001", "text": "좋은 기획 문서(PRD)의 조건은 무엇이라고 생각하나요?", "category": "technical", "difficulty": "basic", "keywords": ["PRD", "기획서", "문서화", "커뮤니케이션"], "evaluationHints": "기획 문서 구성 요소와 목적 이해"},
    {"id": "pm-002", "text": "프로젝트 일정 관리를 어떻게 하나요? 사용하는 도구나 방법론이 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["일정 관리", "간트 차트", "스프린트", "도구"], "evaluationHints": "구체적 도구와 방법론 경험"},
    {"id": "pm-003", "text": "애자일(Agile)과 워터폴(Waterfall) 방식의 차이점을 설명해주세요. 어떤 상황에 어떤 방식이 적합한가요?", "category": "technical", "difficulty": "intermediate", "keywords": ["애자일", "워터폴", "스크럼", "개발 방법론"], "evaluationHints": "방법론 이해와 상황별 적용"},
    {"id": "pm-004", "text": "기획 의도와 개발 결과물이 다를 때 어떻게 대처하나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["커뮤니케이션", "기획 변경", "이해관계"], "evaluationHints": "상황 대처와 소통 방법"},
    {"id": "pm-005", "text": "유저 리서치를 진행한 경험이 있나요? 어떤 방법을 사용했고, 인사이트를 어떻게 반영했나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["유저 리서치", "인터뷰", "설문", "인사이트"], "evaluationHints": "리서치 방법과 데이터 활용"},
    {"id": "pm-006", "text": "제품의 핵심 가치(Value Proposition)를 정의한 경험이 있나요? 어떻게 접근했나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["가치 제안", "제품 전략", "USP"], "evaluationHints": "제품 전략 수립 능력"},
    {"id": "pm-007", "text": "KPI를 설정하고 추적한 경험이 있나요? 어떤 지표를 중요하게 봤나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["KPI", "지표", "전환율", "리텐션", "데이터"], "evaluationHints": "지표 설정과 데이터 기반 의사결정"},
    {"id": "pm-008", "text": "비즈니스 모델(BM)을 기획하거나 분석한 경험이 있나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["BM", "수익 모델", "구독", "SaaS", "광고"], "evaluationHints": "BM 구조 이해와 수익/사용자 경험 균형"},
    {"id": "pm-009", "text": "A/B 테스트를 설계하거나 진행한 경험이 있나요? 결과를 어떻게 판단했나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["A/B 테스트", "실험", "가설", "통계"], "evaluationHints": "실험 설계 능력과 데이터 해석"},
    {"id": "pm-010", "text": "경쟁 제품 분석(벤치마크)을 어떻게 하나요? 실제로 해본 경험이 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["벤치마크", "경쟁 분석", "시장 조사"], "evaluationHints": "분석 프레임워크와 결과 활용"},
    {"id": "pm-011", "text": "UI/UX를 기획할 때 가장 중요하게 생각하는 것은 무엇인가요?", "category": "technical", "difficulty": "basic", "keywords": ["UI", "UX", "사용성", "직관성"], "evaluationHints": "유저 관점의 UI/UX 이해"},
    {"id": "pm-012", "text": "개발팀과 의견이 충돌할 때 어떻게 설득하거나 조율하나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["설득", "조율", "갈등 해결", "커뮤니케이션"], "evaluationHints": "구체적 경험과 소통 방식"},
    {"id": "pm-013", "text": "스코프 변경이 발생했을 때 어떻게 대응하나요? 우선순위는 어떻게 결정하나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["스코프", "변경 관리", "우선순위", "MVP"], "evaluationHints": "변경 관리 프로세스와 판단 기준"},
    {"id": "pm-014", "text": "JIRA, Notion, Confluence 등 프로젝트 관리 도구를 사용한 경험이 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["JIRA", "Notion", "협업 도구", "이슈 트래킹"], "evaluationHints": "도구 활용 경험과 워크플로"},
    {"id": "pm-015", "text": "기능 우선순위를 정할 때 어떤 프레임워크를 사용하나요? (예: RICE, MoSCoW 등)", "category": "technical", "difficulty": "intermediate", "keywords": ["우선순위", "RICE", "MoSCoW", "백로그"], "evaluationHints": "프레임워크 이해와 실무 적용"},
    {"id": "pm-016", "text": "가장 최근에 참여한 프로젝트에 대해 설명해주세요. 본인의 역할과 기여는?", "category": "behavioral", "difficulty": "basic", "keywords": ["프로젝트", "역할", "기여", "성과"], "evaluationHints": "구체적 기여와 결과"},
    {"id": "pm-017", "text": "실패한 프로젝트나 기각된 기획안이 있나요? 그 경험에서 무엇을 배웠나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["실패", "교훈", "성장"], "evaluationHints": "실패 인정과 교훈 도출"},
    {"id": "pm-018", "text": "자주 사용하는 서비스 하나를 골라 PM 관점에서 분석해주세요.", "category": "technical", "difficulty": "basic", "keywords": ["서비스 분석", "장단점", "비판적 사고", "개선안"], "evaluationHints": "PM 관점의 분석력과 개선 제안"},
    {"id": "pm-019", "text": "데이터 분석 도구(엑셀, SQL, GA 등)를 사용해본 경험이 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["데이터 분석", "엑셀", "SQL", "분석 도구"], "evaluationHints": "데이터 활용 능력"},
    {"id": "pm-020", "text": "제품 출시 후 운영(업데이트, 이벤트, CS 대응 등) 경험이 있나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["라이브 서비스", "운영", "업데이트", "CS"], "evaluationHints": "서비스 운영 이해와 경험"},
    {"id": "pm-021", "text": "기획 문서를 작성할 때 본인만의 원칙이나 프로세스가 있나요?", "category": "technical", "difficulty": "basic", "keywords": ["기획 문서", "문서화", "프로세스", "원칙"], "evaluationHints": "체계적 문서화 능력"},
    {"id": "pm-022", "text": "이해관계자(Stakeholder)가 서로 다른 요구를 할 때 어떻게 조율하나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["이해관계자", "조율", "커뮤니케이션", "설득"], "evaluationHints": "이해관계 조율 능력과 경험"},
    {"id": "pm-023", "text": "MVP(최소 기능 제품)를 정의한 경험이 있나요? 어떤 기준으로 스코프를 잡았나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["MVP", "스코프", "린", "검증"], "evaluationHints": "MVP 개념 이해와 실무 적용"},
    {"id": "pm-024", "text": "최근 IT/서비스 업계 트렌드 중 관심 있는 것은 무엇인가요?", "category": "behavioral", "difficulty": "basic", "keywords": ["트렌드", "시장", "기술", "관심"], "evaluationHints": "업계 관심과 정보 수집 방법"},
    {"id": "pm-025", "text": "QA(품질 보증) 프로세스에서 PM의 역할은 무엇이라고 생각하나요?", "category": "technical", "difficulty": "basic", "keywords": ["QA", "테스트", "품질", "PM 역할"], "evaluationHints": "QA 프로세스 이해와 PM 관점"},
    {"id": "pm-026", "text": "제품의 사용자 퍼널(Funnel)을 분석하고 개선한 경험이 있나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["퍼널", "전환율", "이탈", "최적화"], "evaluationHints": "퍼널 분석 이해와 개선 사례"},
    {"id": "pm-027", "text": "글로벌 서비스를 위한 현지화(로컬라이제이션)에 대해 어떻게 생각하나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["현지화", "글로벌", "문화", "번역"], "evaluationHints": "현지화 이해와 고려 사항"},
    {"id": "pm-028", "text": "마감이 촉박한 상황에서 스코프를 줄여야 한다면 어떤 기준으로 결정하나요?", "category": "behavioral", "difficulty": "intermediate", "keywords": ["스코프", "우선순위", "MVP", "의사결정"], "evaluationHints": "판단 기준과 실제 경험"},
    {"id": "pm-029", "text": "5년 후 어떤 PM으로 성장하고 싶은지 말씀해주세요.", "category": "behavioral", "difficulty": "basic", "keywords": ["목표", "커리어", "성장"], "evaluationHints": "구체적 비전"}
