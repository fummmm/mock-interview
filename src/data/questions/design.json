    {"id": "design-025", "text": "게임의 난이도 설계는 어떻게 접근하나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["난이도", "학습 곡선", "플로우", "도전"], "evaluationHints": "난이도 곡선 설계 이해"},
    {"id": "design-026", "text": "라이브 서비스 게임의 시즌/이벤트를 기획해본 경험이 있나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["라이브 서비스", "시즌", "이벤트", "운영"], "evaluationHints": "라이브 운영 기획 경험"},
    {"id": "design-027", "text": "새로운 기술이나 도구를 배울 때 어떤 방법으로 학습하나요?", "category": "behavioral", "difficulty": "basic", "keywords": ["학습", "자기 주도", "성장"], "evaluationHints": "학습 방법과 자기 주도성"},
