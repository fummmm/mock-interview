{
  "track": "design",
  "trackLabel": "게임기획",
  "questions": [
    {"id": "design-intro", "text": "자기소개와 함께 게임 기획자를 지망하게 된 계기를 말씀해주세요.", "category": "behavioral", "difficulty": "basic", "keywords": ["자기소개", "게임기획", "지원 동기"], "evaluationHints": "간결한 자기소개, 기획자 지망 이유"},
    {"id": "design-001", "text": "게임 기획자의 역할은 무엇이라고 생각하나요?", "category": "technical", "difficulty": "basic", "keywords": ["기획자 역할", "정의", "책임"], "evaluationHints": "기획자 역할의 범위와 책임 이해"},
    {"id": "design-002", "text": "좋은 게임의 조건은 무엇이라고 생각하나요? 구체적인 게임을 예시로 들어주세요.", "category": "technical", "difficulty": "basic", "keywords": ["좋은 게임", "재미", "게임 디자인"], "evaluationHints": "자신만의 기준과 분석적 사고"},
    {"id": "design-003", "text": "게임의 코어 루프(Core Loop)란 무엇이고, 왜 중요한가요?", "category": "technical", "difficulty": "intermediate", "keywords": ["코어 루프", "리텐션", "게임 메카닉"], "evaluationHints": "코어 루프 개념과 설계 원칙"},
    {"id": "design-004", "text": "전투 시스템을 기획한다면 어떤 요소를 먼저 정의하나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["전투 시스템", "액션", "밸런스", "피드백"], "evaluationHints": "시스템 설계 접근법"},
    {"id": "design-005", "text": "레벨 디자인의 핵심 원칙은 무엇이라고 생각하나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["레벨 디자인", "난이도 곡선", "페이싱", "플로우"], "evaluationHints": "레벨 디자인 이론과 경험"},
    {"id": "design-006", "text": "밸런스 설계를 어떻게 접근하나요? 수치 작업 경험이 있나요?", "category": "technical", "difficulty": "intermediate", "keywords": ["밸런스", "수치", "스프레드시트", "시뮬레이션"], "evaluationHints": "밸런스 접근법과 도구 활용"},
    {"id": "design-007", "text": "내러티브(스토리)가 게임플레이에 어떻게 영향을 미친다고 생각하나요?", "category": "technical", "difficulty": "basic", "keywords": ["내러티브", "스토리", "몰입", "세계관"], "evaluationHints": "스토리와 게임플레이 연결 이해"},
    {"id": "design-008", "text": "F2P 게임에서 유저 경험을 해치지 않는 수익화 방법은?", "category": "technical", "difficulty": "intermediate", "keywords": ["F2P", "수익화", "BM", "유저 경험"], "evaluationHints": "BM과 UX 균형에 대한 이해"},
